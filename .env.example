# wanman-rapid-agent configuration
# Copy this file to .env and fill in the values

# GitHub — required for issue fetching and label/comment operations
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_REPOSITORY=owner/repo

# Google Cloud — required for Vertex AI classification
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Google Cloud — optional (defaults shown)
# GOOGLE_CLOUD_LOCATION=us-central1
# VERTEX_MODEL=gemini-1.5-flash

# Cloud Storage — optional run-report persistence
# GCS_BUCKET=your-gcs-bucket-name
# GCS_PREFIX=triage-runs

# Safety — set to "false" to actually write labels/comments to GitHub
# Default is "true" (dry-run mode: no mutations on GitHub)
# DRY_RUN=true
